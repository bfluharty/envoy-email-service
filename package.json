{
  "name": "envoy-email-service",
  "version": "1.0.0",
  "description": "Lambda + HTTP API for send-on-behalf and inbox. Called by envoy-project-management.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "start": "tsc && node dist/local-server.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3"
  }
}
